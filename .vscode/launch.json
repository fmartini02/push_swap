{
    "version": "0.2.0",
    "configurations": [
    {
      "name": "(gdb) Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/push_swap",
      "args": ["-2 98 4 78 84 7 30 16 57 13 70 1 32 61 96 5 12 72 31 3 15 52 36 93 53 80 -88 18 73 81 100 8 41 11 21 66 97 23 34 85 89 62 25 46 27 77 76 54 71 68 26 20 58 35 9 22 39 24 59 44 28 43 33 67 92 40 83 51 74 69 45 47 94 75 91 38 82 95 56 55 42 48 37 65 79 10 19 86 17 64 60 87 29 49 99 90 50 63 6 14"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands":
      [
          {
              "description": "Enable pretty-printing for gdb",
              "text": "-enable-pretty-printing",
              "ignoreFailures": true
          },
          {
              "description": "Set Disassembly Flavor to Intel",
              "text": "-gdb-set disassembly-flavor intel",
              "ignoreFailures": true
          }
      ]
    }
    ]
  }